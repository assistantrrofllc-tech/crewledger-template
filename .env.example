# CrewLedger Environment Configuration
# Copy this file to .env and fill in your values

# Twilio
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_TOKEN
TWILIO_PHONE_NUMBER=+10000000000

# OpenAI (GPT-4o-mini Vision for receipt OCR)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Ollama (local AI processing — optional)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Database
DATABASE_PATH=data/crewledger.db

# Image Storage
RECEIPT_STORAGE_PATH=storage/receipts

# Email Reports (for weekly accountant reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_EMAIL@gmail.com
SMTP_PASSWORD=YOUR_APP_PASSWORD
ACCOUNTANT_EMAIL=accountant@clientcompany.com

# Application
APP_HOST=0.0.0.0
APP_PORT=5001
APP_DEBUG=false
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING
